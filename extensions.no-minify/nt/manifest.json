{
   "action": {
      "default_icon": {
         "16": "icons/icon16.png",
         "48": "icons/icon48.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "*://www.youtube.com/*", "*://music.youtube.com/*" ],
      "run_at": "document_idle"
   } ],
   "description": "Prevents YouTube from pausing playback and asking 'Video paused. Continue watching?'",
   "host_permissions": [ "*://www.youtube.com/*", "*://music.youtube.com/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "YouTube NonStop +",
   "permissions": [ "storage", "scripting" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "3.0.1",
   "web_accessible_resources": [ {
      "matches": [ "*://www.youtube.com/*", "*://music.youtube.com/*" ],
      "resources": [ "fonts/*" ]
   } ]
}
